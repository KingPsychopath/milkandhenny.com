# Copy this file to .env.local for local development.
# Configure production values in Railway. Never commit real credentials or tokens.

# ─── Required: public browser configuration ───
# Every VITE_* value is embedded in the browser bundle and must never contain a secret.
VITE_BASE_URL=https://milkandhenny.com
VITE_MEDIA_PUBLIC_URL=https://pics.milkandhenny.com

# ─── Required: Cloudflare R2 object storage ───
# Use a least-privilege token with Object Read & Write for these two buckets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_BUCKET=milkandhenny-pics
R2_PRIVATE_BUCKET=milkandhenny-private

# ─── Required: Redis application state ───
REDIS_REST_URL=
REDIS_REST_TOKEN=

# ─── Required: authentication ───
# AUTH_SECRET must contain at least 32 characters. Generate one with: openssl rand -hex 32
AUTH_SECRET=
# Use independent values for each gate. ADMIN_PASSWORD must contain at least 12 characters.
STAFF_PIN=
ADMIN_PASSWORD=
UPLOAD_PIN=

# ─── Optional: scheduled maintenance ───
# Set both when running `pnpm maintenance` from Railway Cron or another scheduler.
# Generate CRON_SECRET with: openssl rand -hex 32
# CRON_SECRET=
# APP_BASE_URL=https://milkandhenny.com

# ─── Optional: media processing ───
# Safe defaults are shown. Configure worker values only after deploying the media worker.
# MEDIA_PROCESSOR_MODE=local
# VITE_TRANSFER_MEDIA_BROWSER_PREP=auto # auto | off
# TRANSFER_MEDIA_WAKE_URL=https://worker.example.com/wake
# TRANSFER_MEDIA_WAKE_TOKEN=
# REDIS_URL=rediss://default:password@host:6379
# TRANSFER_MEDIA_WORKER_CONCURRENCY=1
# TRANSFER_MEDIA_WORKER_ERROR_BACKOFF_MS=15000
# TRANSFER_MEDIA_LOCAL_RAW_TIMEOUT_MS=12000
# TRANSFER_MEDIA_LOCAL_VIDEO_TIMEOUT_MS=8000

# ─── Optional: external multi-file ZIP service ───
# VITE_MULTI_FILE_ZIP_MODE=auto # auto | client
# VITE_MULTI_FILE_ZIP_URL=https://zip-worker.example.com

# ─── Optional: storage and CLI tuning ───
# Defaults are normally appropriate and may be omitted.
# R2_RETRIES=4
# R2_RETRY_BASE_DELAY_MS=400
# R2_MAX_SOCKETS=50
# R2_SOCKET_ACQUISITION_WARNING_TIMEOUT_MS=10000
# MH_CLI_IO_CONCURRENCY=8

# ─── Optional: runtime metadata shown by /api/health ───
# APP_ENV=development
# APP_VERSION=0.1.0
# Railway supplies RAILWAY_GIT_COMMIT_SHA automatically; use this elsewhere.
# APP_COMMIT_SHA=
