# Copy this file to .env.local for local development. The same contract works
# on Railway, another container host, or a VPS.

# ─── Runtime identity (optional, useful on /health) ───
APP_ENV=development
APP_VERSION=0.1.0
# APP_COMMIT_SHA=

# ─── Object storage ───
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# ─── Public URLs (embedded in the browser build) ───
VITE_MEDIA_PUBLIC_URL=https://pics.milkandhenny.com
# Canonical site URL — used by app + CLI for share links, sitemap, RSS
VITE_BASE_URL=https://milkandhenny.com

# ─── Persistent application state ───
# Use the REST credentials supplied by your Redis provider.
REDIS_REST_URL=
REDIS_REST_TOKEN=

# ─── Auth (token-based: verify → JWT, never store credentials) ───
# AUTH_SECRET: JWT signing key. Generate: openssl rand -hex 32.
# Must be at least 32 chars (weak values are rejected at runtime).
AUTH_SECRET=

# ─── Guest list: two gates (both server-verified, not in repo) ───
# STAFF_PIN: PIN to open the guestlist page (door staff). Verify: POST /api/guests/verify-staff-pin
STAFF_PIN=
# ADMIN_PASSWORD: Admin gate for management tools and admin dashboard.
# Short/weak values will show up as warnings in /api/debug (health/status).
# Verify: POST /api/admin/verify
ADMIN_PASSWORD=

# ─── Upload page: dedicated upload gate ───
# UPLOAD_PIN: PIN to access /upload (shareable with non-admin uploaders). Verify: POST /api/upload/verify-pin
UPLOAD_PIN=

# ─── Transfers ───
# TRANSFER_ID_STYLE: "words" (default) = human-readable 3-word combos (velvet-moon-candle)
#                    "random" = 11-char base64url strings
# TRANSFER_ID_STYLE=words

# ─── Media processing ───
# local  = no worker, local processing only
# hybrid = local images, queue RAW/video for the optional worker
# worker = queue supported advanced formats for the optional worker
MEDIA_PROCESSOR_MODE=local
VITE_TRANSFER_MEDIA_BROWSER_PREP=auto
# Configure these only when a dedicated worker is deployed.
# TRANSFER_MEDIA_WAKE_URL=https://worker.example.com/wake
# TRANSFER_MEDIA_WAKE_TOKEN=
# REDIS_URL=rediss://... # direct Redis connection used by the worker

# ─── Scheduled maintenance ───
# Generate with: openssl rand -hex 32
CRON_SECRET=
# Used by `pnpm maintenance`; defaults to VITE_BASE_URL when omitted.
# APP_BASE_URL=https://milkandhenny.com
